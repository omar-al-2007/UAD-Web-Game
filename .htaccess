# ======================================================
# .htaccess Configuration - تحسينات الأمان والأداء
# ======================================================

# تفعيل Gzip Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
  AddOutputFilterByType DEFLATE text/x-component text/x-cross-domain-policy
  <FilesMatch "\.(js|css|xml|gz)$">
    Header append Content-Encoding gzip
  </FilesMatch>
</IfModule>

# تحسين Cache Headers
<IfModule mod_expires.c>
  ExpiresActive On
  
  # صور - 1 شهر
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/gif "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  
  # CSS و JavaScript - 1 أسبوع
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType text/javascript "access plus 1 week"
  
  # Fonts - 1 سنة
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
  ExpiresByType application/x-font-ttf "access plus 1 year"
  ExpiresByType application/x-font-opentype "access plus 1 year"
  
  # HTML - لا تخزن مؤقتاً
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType application/json "access plus 0 seconds"
  ExpiresByType application/xml "access plus 0 seconds"
</IfModule>

# منع الوصول للملفات الحساسة
<FilesMatch "^(\.|service-worker\.js|README\.md|package\.json)">
  Order allow,deny
  Deny from all
</FilesMatch>

# تحويل الأخطاء إلى صفحات صديقة
ErrorDocument 404 /index.html
ErrorDocument 500 /index.html

# إعادة توجيه من HTTP إلى HTTPS
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
  
  # إزالة trailing slashes
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/$ /$1 [L,R=301]
  
  # Rewrite URLs بدون .html extension
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^([^.]+)$ $1.html [L]
</IfModule>

# Security Headers
<IfModule mod_headers.c>
  # منع clickjacking
  Header set X-Frame-Options "SAMEORIGIN"
  
  # منع MIME sniffing
  Header set X-Content-Type-Options "nosniff"
  
  # تفعيل XSS Protection
  Header set X-XSS-Protection "1; mode=block"
  
  # Referrer Policy
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  
  # Permissions Policy
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# مزامنة UTF-8
AddDefaultCharset utf-8
AddCharset UTF-8 .html .css .js .xml .json .txt

# MIME Types
AddType application/json .json
AddType application/manifest+json .webmanifest
AddType application/x-web-app-manifest+json .webapp
AddType text/cache-manifest .appcache
AddType video/mp4 .mp4
AddType video/webm .webm
AddType audio/mp3 .mp3
AddType audio/wav .wav

# ======================================================
# ملاحظة: بعض الخيارات تتطلب تفعيل modules على الخادم
# اتصل بمضيفك إذا لم تعمل بعض الخيارات
# ======================================================
